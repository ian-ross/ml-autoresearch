FROM python:3.12-slim-bookworm

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        bash ca-certificates curl git jq \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY pyproject.toml ./
COPY docs ./docs
COPY src ./src
RUN python -m pip install --no-cache-dir \
    "numpy>=2,<3" \
    "pillow>=10,<12" \
    "pydantic>=2,<3" \
    "PyYAML>=6,<7" \
    "typer>=0.12,<1"
RUN python -m pip install --no-cache-dir --no-deps .
RUN ml-autoresearch-agent --help >/dev/null \
    && mkdir -p /tmp/agent-smoke/runs /tmp/agent-smoke/submissions /tmp/agent-smoke/candidate \
    && cat > /tmp/agent-smoke/candidate/manifest.yaml <<'EOF'
name: candidate
input_mode: single_frame_rgb
output_form: mask_logits
training:
  loss: bce_dice
  optimizer: adamw
  learning_rate: 0.001
  batch_size: 2
  max_epochs: 1
EOF
RUN touch /tmp/agent-smoke/candidate/model.py \
    && printf '%s\n' '# Smoke Candidate' > /tmp/agent-smoke/candidate/README.md \
    && printf '%s\n' 'Hypothesis: smoke' 'Comparison Target: smoke' 'Expected Effect: smoke' 'Implementation Sketch: smoke' 'Contract Features Used: smoke' 'Budget Requested: smoke' 'Success Criteria: smoke' 'Fallback Next Decision: smoke' > /tmp/agent-smoke/candidate/PROPOSAL.md \
    && ml-autoresearch-agent list-runs --runs-root /tmp/agent-smoke/runs >/dev/null \
    && ml-autoresearch-agent validate-candidate --candidate /tmp/agent-smoke/candidate >/dev/null \
    && ml-autoresearch-agent prepare-candidate-submission --candidate /tmp/agent-smoke/candidate --submissions-root /tmp/agent-smoke/submissions >/dev/null \
    && rm -rf /tmp/agent-smoke

WORKDIR /workspace
CMD ["bash"]
